// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
}

model Waitlist {
  id    String @id @default(uuid())
  email String @unique

  source String?

  joinedAt    DateTime  @default(now())
  verifiedAt  DateTime?
  convertedAt DateTime?
}
